# ============================================
# GlowStudio AI - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env

# --- Aplicação ---
APP_NAME=GlowStudio AI
APP_ENV=development
APP_DEBUG=true
APP_PORT=8501
APP_SECRET_KEY=              # python -c "import secrets; print(secrets.token_hex(32))"

# --- Maritaca AI (Geração de Texto / Legenda) ---
MARITACA_API_KEY=            # Obtenha em: https://chat.maritaca.ai
MARITACA_MODEL=sabia-3       # Modelos disponíveis: sabia-3, sabia-3-small

# --- Fal.ai (Geração de Imagem + Vídeo via Kling) ---
FAL_API_KEY=                 # Obtenha em: https://fal.ai/dashboard/keys

# --- Supabase (Banco de Dados / Auth) ---
SUPABASE_URL=                # Obtenha no Dashboard do Supabase (Project Settings > API)
SUPABASE_KEY=                # Utilize a chave pública (anon key)

# --- Armazenamento ---
UPLOAD_MAX_SIZE_MB=10
UPLOAD_ALLOWED_EXTENSIONS=png,jpg,jpeg,webp

# --- Logs ---
LOG_LEVEL=INFO
